{
    "name": "Cookie-Poster",
    "description": "Open-source developer extension for testing authenticated cookie flows, without tracking users or storing browsing history",
    "version": "0.0.2",
    "manifest_version": 3,
    "permissions": ["activeTab", "tabs", "cookies", "storage"],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "src/assets/icon-16.png",
            "32": "src/assets/icon-32.png",
            "48": "src/assets/icon-48.png",
            "128": "src/assets/icon-128.png"
        }
    },
    "options_ui": {
        "page": "src/options/options.html",
        "open_in_tab": true
    },
    "icons": {
        "16": "src/assets/icon-16.png",
        "32": "src/assets/icon-32.png",
        "48": "src/assets/icon-48.png",
        "128": "src/assets/icon-128.png"
    },
    "incognito": "split",
    "background": {
        "service_worker": "build/background/service-worker.js",
        "type": "module"
    }
}
